<?xml version="1.0" encoding="utf-8"?>
<project>
	<app title="FNF: VS Impostor V4" file="VSImpostorV4" packageName="com.brenninho.impostormobile" package="com.brenninho.impostormobile" main="Main" version="0.2.7" company="Brenninho" />

	<set name="APP_ID" value="0x0100f6c013bbc000" />
	<app preloader="flixel.system.FlxPreloader" />
	<set name="SWF_VERSION" value="11.8" />

	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" />
	<window if="html5" resizable="true" />
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" vsync="false" />
	<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0" resizable="false" />
	<window if="switch" orientation="landscape" fullscreen="true" width="0" height="0" resizable="true" />

	<set name="BUILD_DIR" value="export/debug" if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />
	<set name="BUILD_DIR" value="export/32bit" if="32" />

	<classpath name="source" />

	<assets path="assets/preload" rename="assets" exclude="*.ogg" if="web" />
	<assets path="assets/preload" rename="assets" exclude="*.mp3" unless="web" />

	<define name="MODS_ALLOWED" if="desktop" />
	<define name="LUA_ALLOWED" if="windows" />
	<define name="VIDEOS_ALLOWED" if="web || windows" unless="32" />
	<define name="MOBILE_BUILD" if="mobile" />

	<define name="PRELOAD_ALL" unless="web" />
	<define name="NO_PRELOAD_ALL" unless="PRELOAD_ALL" />

	<library name="videos" preload="true" />

	<section if="PRELOAD_ALL">
		<library name="songs" preload="true" />
		<library name="shared" preload="true" />
		<library name="impostor" preload="true" />
	</section>

	<section if="NO_PRELOAD_ALL">
		<library name="songs" preload="false" />
		<library name="shared" preload="false" />
		<library name="impostor" preload="false" />
	</section>

	<assets path="plugins/" rename="" if="VIDEOS_ALLOWED windows" />
	<assets path="dlls/" rename="" if="VIDEOS_ALLOWED windows" />
	<assets path="assets/videos" library="videos" if="VIDEOS_ALLOWED" />
	<assets path="assets/songs" library="songs" exclude="*.ogg" if="web" />
	<assets path="assets/songs" library="songs" exclude="*.mp3" unless="web" />
	<assets path="assets/shared" library="shared" exclude="*.ogg" if="web" />
	<assets path="assets/shared" library="shared" exclude="*.mp3" unless="web" />
	<assets path="assets/impostor" library="impostor" exclude="*.ogg" if="web" />
	<assets path="assets/impostor" library="impostor" exclude="*.mp3" unless="web" />
	<assets path="assets/fonts" embed="true" />

	<android target-sdk-version="34" minimum-sdk-version="21" />

	<permission android:name="android.permission.INTERNET" />
	<permission android:name="android.permission.VIBRATE" />
	<permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" if="mobile" />
	<permission android:name="android.permission.READ_EXTERNAL_STORAGE" if="mobile" />

	<haxelib name="flixel" />
	<haxedev set="webgl" />
	<haxelib name="flixel-addons" />
	<haxelib name="hscript" />
	<haxelib name="flixel-ui" />
	<haxelib name="linc_luajit" if="LUA_ALLOWED" />
	<haxelib name="faxe" if="switch" />
	<haxelib name="discord_rpc" if="desktop" />

	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
	<haxedef name="FLX_NO_DEBUG" unless="debug" />
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />
	<haxedef name="FLX_NO_TOUCH" if="desktop" />
	<haxedef name="FLX_NO_KEYBOARD" if="mobile" />
	<haxedef name="FLX_NO_MOUSE" if="mobile" />

	<icon path="art/icon16.png" size="16" />
	<icon path="art/icon32.png" size="32" />
	<icon path="art/icon64.png" size="64" />
	<icon path="art/iconOG.png" />
</project>